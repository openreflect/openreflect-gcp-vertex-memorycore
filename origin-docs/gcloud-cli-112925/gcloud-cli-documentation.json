  },
  "overview": {
    "description": "The gcloud CLI manages authentication, local configuration, developer workflow, and interactions with the Google Cloud APIs. It is the command-line interface for Google Cloud Platform.",
    "purpose": "Manage Google Cloud resources and developer workflow",
    "cheatSheet": "https://cloud.google.com/sdk/docs/cheatsheet"
  },
  "installation": {
    "platforms": [
      "Windows",
      "macOS",
      "Linux"
    ],
    "download": "https://cloud.google.com/sdk/docs/install",
    "components": "Use 'gcloud components install COMPONENT' to install additional components"
  },
  "authentication": {
    "methods": [
      {
        "name": "gcloud auth login",
        "description": "Authenticate with a Google account",
        "usage": "gcloud auth login [ACCOUNT]"
      },
      {
        "name": "gcloud auth application-default login",
        "description": "Set up Application Default Credentials (ADC) for local development",
        "usage": "gcloud auth application-default login"
      },
      {
        "name": "Service Account",
        "description": "Authenticate using service account keys",
        "usage": "gcloud auth activate-service-account --key-file=KEY_FILE"
      }
    ],
    "accountManagement": {
      "list": "gcloud auth list",
      "setAccount": "gcloud config set account ACCOUNT",
      "revoke": "gcloud auth revoke ACCOUNT"
    }
  },
  "configuration": {
    "configManagement": {
      "list": "gcloud config list",
      "getValue": "gcloud config get-value PROPERTY",
      "set": "gcloud config set PROPERTY VALUE",
      "unset": "gcloud config unset PROPERTY"
    },
    "commonProperties": {
      "core/account": "Google Cloud user account to use",
      "core/project": "Default Google Cloud project ID",
      "compute/region": "Default compute region",
      "compute/zone": "Default compute zone"
    },
    "configurations": {
      "description": "Multiple named configurations for different projects/environments",
      "create": "gcloud config configurations create CONFIG_NAME",
      "activate": "gcloud config configurations activate CONFIG_NAME",
      "list": "gcloud config configurations list"
    }
  },
  "globalFlags": {
    "--account": "Google Cloud user account to use for invocation",
    "--project": "The Google Cloud project ID to use for this invocation",
    "--billing-project": "The Google Cloud project that will be charged quota for operations",
    "--configuration": "File name of the configuration to use",
    "--format": "Sets the format for printing command output (json, yaml, table, etc.)",
    "--quiet": "Disable all interactive prompts",
    "--verbosity": "Override the default verbosity (debug, info, warning, error, critical, none)",
    "--help": "Display detailed help",
    "--flags-file": "A YAML or JSON file that specifies a --flag:value dictionary",
    "--flatten": "Flatten name[] output resource slices",
    "--impersonate-service-account": "Impersonate a service account"
  },
  "commandStructure": {
    "format": "gcloud GROUP | COMMAND [FLAGS]",
