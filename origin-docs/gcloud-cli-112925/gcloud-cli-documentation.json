    }
  },
  "keyCommands": {
    "authentication": {
      "login": "gcloud auth login",
      "list": "gcloud auth list",
      "applicationDefaultLogin": "gcloud auth application-default login",
      "activateServiceAccount": "gcloud auth activate-service-account --key-file=KEY_FILE"
    },
    "configuration": {
      "list": "gcloud config list",
      "getValue": "gcloud config get-value PROPERTY",
      "set": "gcloud config set PROPERTY VALUE",
      "unset": "gcloud config unset PROPERTY",
      "setProject": "gcloud config set project PROJECT_ID",
      "setAccount": "gcloud config set account ACCOUNT"
    },
    "projectManagement": {
      "list": "gcloud projects list",
      "describe": "gcloud projects describe PROJECT_ID",
      "create": "gcloud projects create PROJECT_ID",
      "set": "gcloud config set project PROJECT_ID"
    },
    "services": {
      "list": "gcloud services list",
      "enable": "gcloud services enable SERVICE_NAME",
      "disable": "gcloud services disable SERVICE_NAME",
      "listEnabled": "gcloud services list --enabled"
    },
    "compute": {
      "instances": {
        "list": "gcloud compute instances list",
        "create": "gcloud compute instances create INSTANCE_NAME",
        "describe": "gcloud compute instances describe INSTANCE_NAME",
        "delete": "gcloud compute instances delete INSTANCE_NAME"
      },
      "zones": "gcloud compute zones list",
      "regions": "gcloud compute regions list"
    },
    "cloudRun": {
      "servicesList": "gcloud run services list",
      "servicesDescribe": "gcloud run services describe SERVICE_NAME",
      "servicesDeploy": "gcloud run deploy SERVICE_NAME --image IMAGE",
      "servicesDelete": "gcloud run services delete SERVICE_NAME"
    },
    "vertexAI": {
      "aiModelsList": "gcloud ai models list",
      "aiEndpointsList": "gcloud ai endpoints list",
      "aiCustomJobsList": "gcloud ai custom-jobs list"
    },
    "iam": {
      "rolesList": "gcloud iam roles list",
      "serviceAccountsList": "gcloud iam service-accounts list",
      "serviceAccountsCreate": "gcloud iam service-accounts create NAME",
      "policyBinding": "gcloud projects add-iam-policy-binding PROJECT_ID --member=MEMBER --role=ROLE"
    },
    "storage": {
      "bucketsList": "gcloud storage buckets list",
      "bucketsCreate": "gcloud storage buckets create gs://BUCKET_NAME",
      "cp": "gcloud storage cp SOURCE DESTINATION",
      "ls": "gcloud storage ls"
    }
  },
  "commonWorkflows": {
    "initialSetup": [
      "gcloud auth login",
      "gcloud config set project PROJECT_ID",
      "gcloud config set compute/region REGION",
      "gcloud auth application-default login"
    ],
    "projectSwitching": [
      "gcloud config set project PROJECT_ID",
      "gcloud config get-value project"
    ],
    "serviceAccountUsage": [
      "gcloud auth activate-service-account --key-file=KEY_FILE",
      "gcloud config set account SERVICE_ACCOUNT_EMAIL"
    ],
    "apiManagement": [
      "gcloud services list --enabled",
      "gcloud services enable SERVICE_NAME",
      "gcloud services disable SERVICE_NAME"
    ]
  },
  "filteringAndFormatting": {
    "filter": {
      "description": "Filter resources using expressions",
      "example": "gcloud compute instances list --filter='name:test-* AND zone:us-central1-*'"
    },
    "format": {
      "description": "Format output in various formats",
      "examples": [
        "gcloud projects list --format='table(name,projectId)'",
        "gcloud compute instances list --format='json'",
        "gcloud config get-value project --format='value'"
      ]
    },
    "sortBy": {
      "description": "Sort output by specified fields",
      "example": "gcloud compute instances list --sort-by=~creationTimestamp"
    }
  },
